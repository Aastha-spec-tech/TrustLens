# ── Anakin.io — 3 keys, rotated round-robin ──────────────────────────────────
# Get keys: https://app.anakin.io/settings/api-keys
# Having 3 keys triples your rate limit capacity
ANAKIN_API_KEY_1=your_first_anakin_key
ANAKIN_API_KEY_2=your_second_anakin_key
ANAKIN_API_KEY_3=your_third_anakin_key

# ── LLM — FREE open-source models, pick ONE (or both, Groq tried first) ───────

# Groq: Llama 3.3 70B — 14,400 req/day free, instant key, no card
# https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini 2.0 Flash — 1M tokens/day free, instant key, no card
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Together AI: Llama 3.1 70B — $1 free credit on signup (~500+ audits)
# https://api.together.xyz/settings/api-keys
# TOGETHER_API_KEY=

# ── NVIDIA NIM Embeddings (semantic product similarity) ──────────────────────
# Free: 1000 credits — https://build.nvidia.com  → Get API Key
# Falls back to Jaccard word overlap if not set
# NVIDIA_API_KEY=

# ── MiniMax AI (multi-product comparison analysis) ────────────────────────────
# Free tier — https://platform.minimaxi.com
# Falls back to Groq/Gemini if not set
# MINIMAX_API_KEY=

# ── MongoDB (comparison result persistence) ───────────────────────────────────
# Free cluster: https://cloud.mongodb.com  → Create Free M0
# Falls back to in-memory cache if not set
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/trustlens

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# true = skip all live scraping, always serve demo-data (no keys needed)
DEMO_MODE=false
